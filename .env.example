# --- CORE SETTINGS ---
# It's highly recommended to generate a strong, random secret key.
# You can use `openssl rand -hex 32` in your terminal to generate one.
JWT_SECRET=your_super_secret_key_here

# The base URL for your frontend application (for email links)
SERVER_HOST="http://localhost:8000"

# --- DATABASE ---
# The connection string for your PostgreSQL database.
DATABASE_URL="postgresql+asyncpg://user:password@localhost:5432/bookly_db"

# --- REDIS & CELERY ---
# The connection string for your Redis server.
REDIS_URL="redis://127.0.0.1:6379/0"
CELERY_BROKER_URL="redis://127.0.0.1:6379/0"
CELERY_RESULT_BACKEND="redis://127.0.0.1:6379/0"

# --- EMAIL SETTINGS (Example for Gmail) ---
# Use an App Password from your email provider, not your regular password.
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_16_character_app_password
MAIL_FROM=your_email@gmail.com
MAIL_SERVER=smtp.gmail.com
MAIL_FROM_NAME="Bookly App"
MAIL_DEBUG=True # Set to False in production to send real emails

# --- MIDDLEWARE SETTINGS ---
# Comma-separated list of allowed hosts.
ALLOWED_HOSTS="localhost,127.0.0.1"
# Comma-separated list of allowed origins for CORS.
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"
